        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRESQL}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \r\n    CASE \r\n        -- Pega apenas os últimos dígitos (a idade real) usando MOD (resto da divisão por 1000)\r\n        WHEN MOD(p.idade_codigo, 1000) < 15 THEN 'Criança'\r\n        WHEN MOD(p.idade_codigo, 1000) BETWEEN 15 AND 59 THEN 'Adulto'\r\n        ELSE 'Idoso'\r\n    END AS perfil_paciente, \r\n    SUM(f.qtd_casos) AS total_casos \r\nFROM silver.fct_notificacoes f\r\nJOIN silver.dim_paciente p ON f.sk_paciente = p.sk_paciente\r\nGROUP BY 1\r\nORDER BY 2 DESC;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Perfil do Paciente",
      "type": "piechart"
    },
